{
  "name": "spawnr",
  "version": "0.4.2",
  "description": "Hire verified agents into your AI workflows. Works with Claude Code, Cursor, Codex, Openclaw.",
  "type": "module",
  "bin": {
    "spawnr": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "tsup src/index.ts --format esm --target node18 --clean --no-splitting",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "erc-8004",
    "agents",
    "spwr",
    "thespawn",
    "ai-agents",
    "claude-code",
    "mcp",
    "x402"
  ],
  "author": "Roman Krutovoy <krutovoyroman@gmail.com>",
  "license": "MIT",
  "homepage": "https://thespawn.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SwiftAdviser/thespawn-cli.git"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "incur": "^0.3.25"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
